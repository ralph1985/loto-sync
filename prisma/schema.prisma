generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum GroupKind {
  AMIGOS
  TRABAJO
  PAREJA
}

enum DrawType {
  PRIMITIVA
  EUROMILLONES
}

enum TicketStatus {
  PENDIENTE
  COMPROBADO
  PREMIO
}

enum LineNumberKind {
  MAIN
  STAR
}

model Group {
  id          String            @id @default(cuid())
  name        String
  kind        GroupKind?
  tickets     Ticket[]
  movements   GroupMovement[]
  members     GroupMember[]
  invitations GroupInvitation[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

enum GroupMovementType {
  OPENING
  ADJUSTMENT
  CONTRIBUTION
  TICKET_EXPENSE
  PRIZE
}

enum GroupMemberRole {
  OWNER
  MEMBER
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
}

model User {
  id                  String            @id @default(cuid())
  name                String            @unique
  passwordHash        String
  memberships         GroupMember[]
  invitationsSent     GroupInvitation[] @relation("InvitationInviter")
  invitationsReceived GroupInvitation[] @relation("InvitationInvitee")
  auditLogs           AuditLog[]
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
}

model GroupMember {
  id        String          @id @default(cuid())
  groupId   String
  group     Group           @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      GroupMemberRole @default(MEMBER)
  createdAt DateTime        @default(now())

  @@unique([groupId, userId])
  @@index([userId])
}

model GroupInvitation {
  id        String           @id @default(cuid())
  groupId   String
  group     Group            @relation(fields: [groupId], references: [id], onDelete: Cascade)
  inviterId String
  inviter   User             @relation("InvitationInviter", fields: [inviterId], references: [id], onDelete: Cascade)
  inviteeId String?
  invitee   User?            @relation("InvitationInvitee", fields: [inviteeId], references: [id], onDelete: SetNull)
  role      GroupMemberRole  @default(MEMBER)
  status    InvitationStatus @default(PENDING)
  note      String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([groupId, status])
  @@index([inviteeId, status])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actor      User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
  entityType String
  entityId   String
  action     String
  payload    Json?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId, createdAt])
  @@index([actorId, createdAt])
}

model GroupMovement {
  id           String            @id @default(cuid())
  groupId      String
  group        Group             @relation(fields: [groupId], references: [id], onDelete: Cascade)
  type         GroupMovementType
  amountCents  Int
  occurredAt   DateTime          @default(now())
  note         String?
  relatedTicketId String?
  relatedCheckId String?
  createdAt    DateTime          @default(now())

  @@index([groupId, occurredAt])
  @@index([relatedTicketId])
  @@index([relatedCheckId])
  @@unique([relatedCheckId, type])
}

model Draw {
  id        String   @id @default(cuid())
  type      DrawType
  drawDate  DateTime
  label     String?
  tickets   Ticket[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([type, drawDate])
  @@index([type, drawDate])
}

model Ticket {
  id         String       @id @default(cuid())
  groupId    String
  group      Group        @relation(fields: [groupId], references: [id])
  drawId     String
  draw       Draw         @relation(fields: [drawId], references: [id])
  status     TicketStatus @default(PENDIENTE)
  priceCents Int?
  playsJoker Boolean      @default(false)
  jokerNumber String?
  notes      String?
  lines      TicketLine[]
  receipt    Receipt?
  checks     TicketCheck[]
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([groupId, drawId])
  @@index([status])
}

model TicketCheck {
  id             String       @id @default(cuid())
  ticketId       String
  ticket         Ticket       @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  drawDate       DateTime
  status         TicketStatus @default(COMPROBADO)
  reason         String?
  winningNumbers Json
  winningStars   Json?
  matchesMain    Int          @default(0)
  matchesStars   Int          @default(0)
  prizeCents     Int?
  prizeSource    String?
  checkedAt      DateTime     @default(now())
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([ticketId, drawDate])
  @@index([ticketId, checkedAt])
}

model TicketLine {
  id         String   @id @default(cuid())
  ticketId   String
  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  complement Int?
  reintegro  Int?
  numbers    TicketLineNumber[]
  lineIndex  Int      @default(1)
  createdAt  DateTime @default(now())

  @@index([ticketId, lineIndex])
}

model TicketLineNumber {
  id        String         @id @default(cuid())
  lineId    String
  line      TicketLine     @relation(fields: [lineId], references: [id], onDelete: Cascade)
  kind      LineNumberKind
  position  Int
  value     Int
  createdAt DateTime       @default(now())

  @@unique([lineId, kind, position])
  @@index([lineId, kind])
}

model Receipt {
  id        String   @id @default(cuid())
  ticketId  String   @unique
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  blobUrl   String
  blobPath  String?
  mimeType  String?
  sizeBytes Int?
  createdAt DateTime @default(now())
}

model ResultCache {
  id        String   @id @default(cuid())
  game      DrawType
  drawDate  DateTime?
  payload   Json
  fetchedAt DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([game, drawDate])
  @@index([game, fetchedAt])
}
