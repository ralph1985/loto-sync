generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum GroupKind {
  AMIGOS
  TRABAJO
  PAREJA
}

enum DrawType {
  PRIMITIVA
  EUROMILLONES
}

enum TicketStatus {
  PENDIENTE
  COMPROBADO
  PREMIO
}

enum LineNumberKind {
  MAIN
  STAR
}

model Group {
  id        String   @id @default(cuid())
  name      String
  kind      GroupKind?
  tickets   Ticket[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Draw {
  id        String   @id @default(cuid())
  type      DrawType
  drawDate  DateTime
  label     String?
  tickets   Ticket[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([type, drawDate])
  @@index([type, drawDate])
}

model Ticket {
  id         String       @id @default(cuid())
  groupId    String
  group      Group        @relation(fields: [groupId], references: [id])
  drawId     String
  draw       Draw         @relation(fields: [drawId], references: [id])
  status     TicketStatus @default(PENDIENTE)
  priceCents Int?
  notes      String?
  lines      TicketLine[]
  receipt    Receipt?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([groupId, drawId])
  @@index([status])
}

model TicketLine {
  id         String   @id @default(cuid())
  ticketId   String
  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  complement Int?
  reintegro  Int?
  numbers    TicketLineNumber[]
  lineIndex  Int      @default(1)
  createdAt  DateTime @default(now())

  @@index([ticketId, lineIndex])
}

model TicketLineNumber {
  id        String         @id @default(cuid())
  lineId    String
  line      TicketLine     @relation(fields: [lineId], references: [id], onDelete: Cascade)
  kind      LineNumberKind
  position  Int
  value     Int
  createdAt DateTime       @default(now())

  @@unique([lineId, kind, position])
  @@index([lineId, kind])
}

model Receipt {
  id        String   @id @default(cuid())
  ticketId  String   @unique
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  blobUrl   String
  blobPath  String?
  mimeType  String?
  sizeBytes Int?
  createdAt DateTime @default(now())
}

model ResultCache {
  id        String   @id @default(cuid())
  game      DrawType
  drawDate  DateTime?
  payload   Json
  fetchedAt DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([game, drawDate])
  @@index([game, fetchedAt])
}
